# AWOW bash backup service — configuration (WI-10.10). Copy to
# /etc/awow-backup/backup.env (or next to backup.sh) and fill in. NOTHING here is
# committed with real values — this .example carries placeholders only. Prefer a
# root-only cifs credentials file over inline passwords.

# ── external-drive target (step 4) ───────────────────────────────────────────
# The USB drive attached to the AWOW. Dated run snapshots (run_<UTC>) live here.
BACKUP_TARGET=/mnt/backup-drive
# Staging dir for the pulled sources before archiving (fast local disk).
BACKUP_STAGING=/var/tmp/awow-backup/staging
# Retention: keep the last N run snapshots, prune older (rotation).
BACKUP_KEEP=7

# ── drive power / spin-down (WI-10.10 DRIVE POWER DESIGN) ─────────────────────
# The backup drive(s) are the box's biggest electrical lever (5–8 W each while
# spinning ≈ the whole CPU). Policy = DYNAMIC standby: backup-standby.service
# sets a conservative default spin-down timeout at boot, and the backup RUN
# disables standby on its target drive(s) at start + RESTORES the timeout on exit
# (trap; fires on failure/interrupt too). This avoids BOTH wear modes — no
# start/stop churn mid-run, and no aggressive-timeout cycling.
#
# Drive(s) to manage — SPACE-SEPARATED /dev/disk/by-id/... paths. Use by-id,
# NEVER sdX: the kernel renumbers sdX across boots/hotplug, by-id is stable.
# EMPTY = the whole feature is a clean no-op (no boot standby, no run-time hold).
#   ls -l /dev/disk/by-id/    # find the stable path for your USB backup enclosure
BACKUP_DRIVE_DEVICES=""
# e.g. BACKUP_DRIVE_DEVICES="/dev/disk/by-id/usb-Seagate_Expansion_0AC1234-0:0 /dev/disk/by-id/usb-WD_Elements_25E1-0:0"
#
# At-rest spin-down timeout — the hdparm -S value. The encoding is notoriously
# confusing, so spelled out:
#     0        = standby DISABLED (never spins down) — what the run uses mid-backup
#     1..240   = value × 5 seconds        (so 240 = 20 min)
#     241..251 = (value − 240) × 30 min   (so 241 = 30 min, 242 = 60 min, …)
# Recommended conservative default: 241 (= 30 min). 240 (= 20 min) is also fine.
BACKUP_DRIVE_STANDBY=241
#
# CAVEAT: many USB-SATA enclosures do NOT honor hdparm APM/standby (the bridge
# chip swallows or fakes the command). When that happens this is a HARMLESS no-op
# — power management NEVER fails a backup (missing hdparm, absent device, or a
# rejecting enclosure → logged WARNING, the run continues). Verify per drive at
# hardware BURN-IN:  hdparm -C /dev/disk/by-id/...   (shows active/idle vs standby;
# spin a drive down with `hdparm -y` and confirm it reports 'standby').

# ── sources (step 1) — ONE table, one `name=SPEC` per line (SR-013) ───────────
# Names become the archive/set names; every set flows through the same
# archive→hash→retention→offsite→report pipeline. SPEC forms:
#   //host/share            cifs pull over the LAN (Samba per D5; original form)
#   volume:VOL              docker named volume on THIS box, copied live
#   volume:VOL@CONTAINER    stop CONTAINER for the copy, restart immediately
#                           after — for volumes holding live databases. The EXIT
#                           trap restarts it even if the run dies mid-copy.
#   path:/abs/dir           a local directory on this box
# Lines starting with # are skipped. volume: specs need the docker CLI (a given
# on the AWOW). Consistency: a live volume copy can catch a DB mid-write —
# prefer @CONTAINER for actual/technitium (downtime = the copy, seconds).
BACKUP_SOURCES="minecraft=//mini-serv/minecraft
satisfactory=//mini-serv/satisfactory
# The box's OWN service state (OI-8 / SN-010) — uncomment to protect it:
# actual=volume:actual_data@actual
# technitium=volume:technitium_config@technitium
# caddy=volume:caddy_data
# tracker=volume:tracker_data@tracker
# finance=volume:finance_snapshots@finance-auditor
"
# PRIVACY (Finance-Auditor §3 firewall): the `finance` set is RAW FINANCIAL
# DATA — it may ride the LOCAL backup drive but must NEVER be added to
# OFFSITE_SETS below (the offsite share is IceDrive CLOUD-synced; raw finance
# data never leaves the LAN).

# cifs credentials for the LAN Samba shares (one Samba local user per D5). Use a
# credentials FILE (root-only, `username=`/`password=` lines) rather than inline.
BACKUP_CIFS_CREDENTIALS=/etc/awow-backup/cifs.creds
# ...or inline (less safe):
# BACKUP_CIFS_USER=awow
# BACKUP_CIFS_PASS=REPLACE
BACKUP_CIFS_EXTRA=vers=3.0

# ── compression (step 2) — auto-compression-where-applicable ─────────────────
# A set whose bytes are >= THRESHOLD% already-compressed is stored as plain .tar;
# otherwise zstd (.tar.zst). Mirrors the FileBackup already-compressed exemption.
BACKUP_ZSTD_LEVEL=10
BACKUP_INCOMPRESSIBLE_THRESHOLD=60
# BACKUP_INCOMPRESSIBLE_EXT="jar zip 7z gz zst png jpg mp4 sav ..."   # override the default set

# ── offsite (step 5) — push into the Windows IceDrive-synced share ───────────
OFFSITE_ENABLED=true
OFFSITE_UNC=//mini-serv/icedrive
# Which sets to push offsite (space-separated; usually a subset — the important
# ones). IceDrive's native app on the Windows box syncs this folder to the cloud.
# Volume sets are ordinary set names here — e.g. add `actual tracker` once those
# sources are uncommented above (the finances belong offsite).
OFFSITE_SETS="minecraft satisfactory"

# ── reporting (step 6) — NagLight /api/feed, never-silent-green ───────────────
# The backup-ran feeder successor. On success posts ok=true; on ANY failure the
# service posts ok=false and exits nonzero.
NAGLIGHT_FEED_URL=https://tracker.example.tld/api/feed
NAGLIGHT_FEED_CHECK=backup
# Bearer token for /api/* POSTs (TRACKER_API_TOKEN on the tracker).
NAGLIGHT_TOKEN=REPLACE_WITH_TRACKER_API_TOKEN
# Multi-user tracker (D3): the stable Google `sub` to attribute the item to,
# sent as X-Forwarded-User directly to the tracker (the documented trust model —
# the feeder is a backend, not a browser). Leave blank for a single-user tracker.
NAGLIGHT_USER=
