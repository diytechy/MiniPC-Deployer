# AWOW AK41 always-on core — configuration.
#
# Copy this to `.env` (same directory) and fill in the values. The autoinstall
# first-boot flow writes a `.env` from these placeholders (see autoinstall/).
# NOTHING here is committed — .env is gitignored; only THIS .example is tracked.
# Every value below is a PLACEHOLDER — fill with your own; never commit a real one.

# ── Domains & network ──────────────────────────────────────────────────────
# Public apex domain your router forwards to this box.
DOMAIN=example.tld
# LAN IP of THIS AWOW box. Split-horizon records point the subdomains here so
# home devices connect directly and TLS still validates.
# Give the box a DHCP reservation / static lease at this address.
LAN_IP=192.168.1.10
# LAN IP of the flaky MAIN box (Minecraft/BlueMap/backups). Used by the
# commented reverse-proxy blocks in the Caddyfile. Blank if none.
MAIN_BOX_IP=192.168.1.20
# Hostname Technitium advertises for itself.
DNS_HOSTNAME=dns.example.tld

# ── Subdomains (each gets a split-horizon A record → LAN_IP) ───────────────
TRACKER_SUBDOMAIN=tracker
ACTUAL_SUBDOMAIN=actual
# 'dns' (Technitium console) and, optionally, a BlueMap subdomain proxied to the
# main box are handled in the Caddyfile / provisioning list.

# ── Caddy / TLS ────────────────────────────────────────────────────────────
# Email for Let's Encrypt / ZeroSSL account (ACME). Required for public certs.
ACME_EMAIL=you@example.tld
# basic_auth for the SINGLE-USER services (Actual, Technitium console). The
# multi-user tracker is NOT basic_auth'd — oauth2-proxy owns its auth (below).
# Generate each hash with:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'yourpass'
ACTUAL_BASICAUTH_USER=admin
ACTUAL_BASICAUTH_HASH=REPLACE_WITH_caddy_hash-password_OUTPUT
DNS_BASICAUTH_USER=admin
DNS_BASICAUTH_HASH=REPLACE_WITH_caddy_hash-password_OUTPUT

# ── oauth2-proxy (Google sign-in for the tracker subdomain) — WI-10.2 / D1/D2 ─
#
# +--------------------- PETER MANUAL STEP (required) ---------------------+
# | Create a Google Cloud OAuth 2.0 Client BEFORE first bring-up:          |
# |  1. console.cloud.google.com -> APIs & Services -> Credentials.        |
# |  2. Configure the OAuth consent screen (External; add each allowed     |
# |     Google account as a Test user while unverified, OR publish it).    |
# |     Scopes: openid, email, profile (the slacker-tracker pattern Peter   |
# |     trusts uses `email profile`).                                      |
# |  3. Create Credentials -> OAuth client ID -> type "Web application".   |
# |  4. Under "Authorized redirect URIs" register EXACTLY:                 |
# |        https://tracker.<your-domain>/oauth2/callback                    |
# |     (substitute TRACKER_SUBDOMAIN + DOMAIN; e.g.                        |
# |        https://tracker.example.tld/oauth2/callback ).                   |
# |     "Authorized JavaScript origins" is not required (server-side flow). |
# |  5. Paste the generated Client ID + Client secret below.              |
# +------------------------------------------------------------------------+
OAUTH2_PROXY_IMAGE_TAG=v7.6.0
OAUTH2_PROXY_CLIENT_ID=REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com
OAUTH2_PROXY_CLIENT_SECRET=REPLACE_WITH_GOOGLE_OAUTH_CLIENT_SECRET
# 32-byte cookie encryption seed. Generate:
#   openssl rand -base64 32 | tr -- '+/' '-_'
OAUTH2_PROXY_COOKIE_SECRET=REPLACE_WITH_openssl_rand_base64_32
# Allow-list of Google accounts permitted through (Q10.5: explicit list to start;
# a remote-settable console is a deferred FUTURE knob, not built). Comma- or
# space-separated. The first-boot flow writes each entry, one per line, into
# oauth2-proxy/authenticated-emails.txt (gitignored) which the container reads.
OAUTH2_PROXY_ALLOWED_EMAILS=you@gmail.com,other-allowed@gmail.com

# ── Technitium DNS ─────────────────────────────────────────────────────────
# Pin a real tag for reproducibility; :latest is fine for first bring-up.
TECHNITIUM_IMAGE_TAG=latest
# Initial admin password (set on first boot; provision script is idempotent).
TECHNITIUM_ADMIN_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD
# API token NAME the provisioning script creates/reuses for headless health/config.
# The token VALUE is generated by Technitium and written to provision/.token
# (gitignored) for later curl-based health checks.
TECHNITIUM_API_TOKEN_NAME=automation
# Upstream forwarders for recursion fallback / DoH. Quad9 DoH by default;
# space-separated. Empty = pure recursion.
TECHNITIUM_FORWARDERS=https://dns.quad9.net/dns-query
# Blocklist URLs (space-separated). Same public lists Pi-hole/AdGuard consume.
TECHNITIUM_BLOCKLISTS=https://raw.githubusercontent.com/StevenBlack/hosts/master/hosts

# ── tracker service (NagLight web container) ───────────────────────────────
# The image is built LOCALLY from a sibling NagLight checkout (Q10.2, no registry
# yet):  docker build -t naglight:local ../NagLight
# Git remote of the DATA repo (your private definitions+logs repo).
# The tracker container clones this into its /data volume on first boot and
# `git pull --rebase` on later boots. Leave blank to manage /data manually.
# NOTE: in multi-user mode (TRACKER_MULTI_USER=true) leave this BLANK and keep
# TRACKER_COMMIT=false — hosted users get per-user data dirs, git stays off (D3).
TRACKER_DATA_REMOTE=
# Identity the tracker uses for its check-off / nightly-materialize commits.
TRACKER_GIT_NAME=naglight bot
TRACKER_GIT_EMAIL=tracker@example.tld
# When true, `tracker serve --commit` — the nightly materialize + check-offs
# commit (and, if the remote is set, push) to the data repo. Single-user only.
TRACKER_COMMIT=true
# Trusted-header multi-user mode (D3, NagLight WI-10.5). true = identity comes
# ONLY from oauth2-proxy's X-Forwarded-Email header; per-user data dir by Google
# `sub`. Keep TRACKER_COMMIT=false and TRACKER_DATA_REMOTE blank when true.
TRACKER_MULTI_USER=false

# ── Image tags (pin for reproducibility) ───────────────────────────────────
CADDY_IMAGE_TAG=2-alpine
# Local NagLight image tag (built with `docker build -t naglight:local ../NagLight`).
TRACKER_IMAGE_TAG=local
ACTUAL_IMAGE_TAG=latest

# ── Host / timezone (used by autoinstall) ──────────────────────────────────
TIMEZONE=Etc/UTC
