#cloud-config
# Ubuntu Server autoinstall (cloud-init) for the AWOW AK41 always-on core.
# Flash USB → boot → everything up, zero clicks.
#
# This is the `autoinstall` user-data consumed by the Ubuntu Server 24.04 LTS
# live installer (Subiquity). It:
#   1. Partitions the whole eMMC/SSD (LVM = simple whole-disk layout).
#   2. Creates the operator user (SSH KEY-ONLY by default — WI-10.12).
#   3. Installs Docker Engine + compose plugin + git + Cockpit via late-commands.
#   4. Enables unattended-upgrades (WI-10.12) for hands-off OS security patching.
#   5. Drops the stack/ tree, a placeholder .env, and a first-boot systemd unit
#      onto the target, then enables the unit so the FIRST real boot runs
#      provisioning + `docker compose up -d`.
#
# SECURITY: replace the identity block below (username + SSH PUBLIC key) and DO
# NOT commit a filled-in copy — this template ships with placeholders. The box is
# key-only; there is no usable password login.
#
# See ../README.md "Build the USB" and ../../REMOTE_MANAGEMENT.md for how to
# attach this file and how to manage the headless box over the LAN.

autoinstall:
  version: 1

  # Non-interactive: never stop to ask. Any prompt would defeat "zero clicks".
  interactive-sections: []

  locale: en_US.UTF-8
  keyboard:
    layout: us

  # DHCP on the first NIC. Give the box a DHCP RESERVATION at your chosen LAN_IP
  # on the router so it always lands where the split-horizon records point.
  network:
    version: 2
    ethernets:
      any-eth:
        match:
          name: "en*"
        dhcp4: true

  identity:
    hostname: awow-core
    realname: "AWOW Core Operator"
    username: operator
    # SSH KEY-ONLY box (WI-10.12): no usable password login. "!" is a locked
    # hash — the account cannot be logged into with a password at all. Console/
    # emergency access is via the physical console only. If you MUST allow a
    # password (not recommended for a headless box) replace this with a real
    # `mkpasswd --method=SHA-512` hash AND set ssh.allow-pw: true below.
    password: "!"

  # Remote management is KEY (WI-10.12): SSH on, KEY-ONLY. Paste your PUBLIC key.
  ssh:
    install-server: true
    allow-pw: false
    authorized-keys:
      # REPLACE with your real public key(s). allow-pw:false above means the box
      # is unreachable over SSH until at least one valid key is present here.
      - "ssh-ed25519 AAAA_REPLACE_WITH_YOUR_PUBLIC_KEY you@host"

  # Whole-disk automatic layout (LVM). The AK41 has a single eMMC/SSD.
  storage:
    layout:
      name: lvm

  packages:
    - ca-certificates
    - curl
    - git
    - dnsutils          # provides dig for the health check
    - apt-transport-https
    - cockpit           # LAN web console (terminal/logs/updates/reboot) — WI-10.12
    - unattended-upgrades  # hands-off OS security patching — WI-10.12
    - powertop          # low-power auto-tune, applied per boot by powertune.service
    - hdparm            # backup-drive spin-down (WI-10.10) — NOT guaranteed on Ubuntu Server

  # Everything site-specific happens in late-commands, which run in the installer
  # environment with the target mounted at /target. We write files INTO /target.
  late-commands:
    # ---- 1. Install Docker Engine from the official repo (inside the target) --
    - curtin in-target --target=/target -- bash -c 'install -m 0755 -d /etc/apt/keyrings'
    - curtin in-target --target=/target -- bash -c 'curl -fsSL https://download.docker.com/linux/ubuntu/gpg -o /etc/apt/keyrings/docker.asc && chmod a+r /etc/apt/keyrings/docker.asc'
    - curtin in-target --target=/target -- bash -c 'echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo $VERSION_CODENAME) stable" > /etc/apt/sources.list.d/docker.list'
    - curtin in-target --target=/target -- bash -c 'apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin'
    - curtin in-target --target=/target -- systemctl enable docker
    - curtin in-target --target=/target -- usermod -aG docker operator

    # ---- 2. Remote management: Cockpit + unattended-upgrades (WI-10.12) --------
    # Cockpit web console on :9090 — LAN-only (do NOT proxy it through Caddy to
    # the public internet). See ../../REMOTE_MANAGEMENT.md.
    - curtin in-target --target=/target -- systemctl enable cockpit.socket
    # Enable unattended security upgrades non-interactively.
    - curtin in-target --target=/target -- bash -c 'echo "unattended-upgrades unattended-upgrades/enable_auto_updates boolean true" | debconf-set-selections'
    - curtin in-target --target=/target -- dpkg-reconfigure -f noninteractive unattended-upgrades
    - curtin in-target --target=/target -- systemctl enable unattended-upgrades

    # ---- 2b. Low-power lightening (Peter, 2026-07-04) --------------------------
    # Nothing in the stack uses snaps; snapd costs RAM + background churn on a
    # low-power box. Purge it. (powertop tuning is applied per-boot by
    # powertune.service, installed in step 5 — auto-tune does not persist.)
    - curtin in-target --target=/target -- bash -c 'DEBIAN_FRONTEND=noninteractive apt-get purge -y snapd 2>/dev/null || true; apt-get autoremove -y --purge'

    # ---- 3. Place the stack ---------------------------------------------------
    # The repo payload is copied by the USB-build step to /cdrom/deploy-payload
    # (a second CIDATA stick, or the remastered ISO) and picked up here into
    # /opt/awow-core/. The stack itself then lives at /opt/awow-core/stack/.
    - mkdir -p /target/opt/awow-core
    - cp -a /cdrom/deploy-payload/. /target/opt/awow-core/ 2>/dev/null || cp -a /media/deploy-payload/. /target/opt/awow-core/ 2>/dev/null || true

    # ---- 4. Seed .env from the example if the operator did not pre-fill one ----
    - curtin in-target --target=/target -- bash -c '[ -f /opt/awow-core/stack/.env ] || cp /opt/awow-core/stack/.env.example /opt/awow-core/stack/.env'

    # ---- 5. Install + enable the first-boot unit ------------------------------
    - cp /target/opt/awow-core/stack/autoinstall/awow-firstboot.service /target/etc/systemd/system/awow-firstboot.service
    - cp /target/opt/awow-core/stack/autoinstall/firstboot.sh /target/usr/local/sbin/awow-firstboot.sh
    - curtin in-target --target=/target -- chmod +x /usr/local/sbin/awow-firstboot.sh
    - curtin in-target --target=/target -- systemctl enable awow-firstboot.service
    # Low-power tune unit (per-boot powertop auto-tune + USB-storage guard).
    - cp /target/opt/awow-core/stack/autoinstall/powertune.service /target/etc/systemd/system/powertune.service
    - cp /target/opt/awow-core/stack/autoinstall/powertune.sh /target/usr/local/sbin/powertune.sh
    - curtin in-target --target=/target -- chmod +x /usr/local/sbin/powertune.sh
    - curtin in-target --target=/target -- systemctl enable powertune.service
    # Backup-drive default standby unit (per-boot hdparm -S spin-down — WI-10.10).
    # Runs from the stack dir (sources common.sh) like awow-backup.service, so we
    # only install the unit + make the script executable; no cp to /usr/local/sbin.
    # A no-op until BACKUP_DRIVE_DEVICES is set in /etc/awow-backup/backup.env.
    - cp /target/opt/awow-core/stack/backup/systemd/backup-standby.service /target/etc/systemd/system/backup-standby.service
    - curtin in-target --target=/target -- chmod +x /opt/awow-core/stack/backup/backup-standby.sh
    - curtin in-target --target=/target -- systemctl enable backup-standby.service

  # No reboot prompt — power-cycle straight into the running box.
  shutdown: reboot
