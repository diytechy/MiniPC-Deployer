# AWOW AK41 always-on core — configuration.
#
# Copy this to `.env` (same directory) and fill in the values. The autoinstall
# first-boot flow writes a `.env` from these placeholders (see autoinstall/).
# NOTHING here is committed — .env is gitignored; only THIS .example is tracked.
# Every value below is a PLACEHOLDER — fill with your own; never commit a real one.

# ── Domains & network ──────────────────────────────────────────────────────
# Public apex domain your router forwards to this box.
DOMAIN=example.tld
# LAN IP of THIS AWOW box. Split-horizon records point the subdomains here so
# home devices connect directly and TLS still validates.
# Give the box a DHCP reservation / static lease at this address.
LAN_IP=192.168.1.10
# LAN IP of the flaky MAIN box (Minecraft/BlueMap/backups). Used by the
# commented reverse-proxy blocks in the Caddyfile. Blank if none.
MAIN_BOX_IP=192.168.1.20
# Hostname Technitium advertises for itself.
DNS_HOSTNAME=dns.example.tld

# ── Subdomains (each gets a split-horizon A record → LAN_IP) ───────────────
TRACKER_SUBDOMAIN=tracker
ACTUAL_SUBDOMAIN=actual
# 'dns' (Technitium console) and, optionally, a BlueMap subdomain proxied to the
# main box are handled in the Caddyfile / provisioning list.

# ── Caddy / TLS ────────────────────────────────────────────────────────────
# Email for Let's Encrypt / ZeroSSL account (ACME). Required for public certs.
ACME_EMAIL=you@example.tld
# basic_auth for the SINGLE-USER services (Actual, Technitium console). The
# multi-user tracker is NOT basic_auth'd — oauth2-proxy owns its auth (below).
# Generate each hash with:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'yourpass'
ACTUAL_BASICAUTH_USER=admin
ACTUAL_BASICAUTH_HASH=REPLACE_WITH_caddy_hash-password_OUTPUT
DNS_BASICAUTH_USER=admin
DNS_BASICAUTH_HASH=REPLACE_WITH_caddy_hash-password_OUTPUT

# ── oauth2-proxy (Google sign-in for the tracker subdomain) — WI-10.2 / D1/D2 ─
#
# +--------------------- PETER MANUAL STEP (required) ---------------------+
# | Create a Google Cloud OAuth 2.0 Client BEFORE first bring-up:          |
# |  1. console.cloud.google.com -> APIs & Services -> Credentials.        |
# |  2. Configure the OAuth consent screen (External; add each allowed     |
# |     Google account as a Test user while unverified, OR publish it).    |
# |     Scopes: openid, email, profile (the slacker-tracker pattern Peter   |
# |     trusts uses `email profile`).                                      |
# |  3. Create Credentials -> OAuth client ID -> type "Web application".   |
# |  4. Under "Authorized redirect URIs" register EXACTLY:                 |
# |        https://tracker.<your-domain>/oauth2/callback                    |
# |     (substitute TRACKER_SUBDOMAIN + DOMAIN; e.g.                        |
# |        https://tracker.example.tld/oauth2/callback ).                   |
# |     "Authorized JavaScript origins" is not required (server-side flow). |
# |  5. Paste the generated Client ID + Client secret below.              |
# +------------------------------------------------------------------------+
# PIN BUMPED 2026-07-10 (review): v7.6.0 → v7.15.2. Multiple auth-bypass
# advisories were fixed between those tags (CVE-2026-34457, CVE-2026-40575,
# GHSA-7x63-xv5r-3p2x, GHSA-pxq7-h93f-9jrg, email-validation GHSA-c5c4-8r6x-56w3)
# and this is the internet-facing front door. NOT yet sim-validated at this tag:
# re-run the AWOW-sim (V1) + vmtest/export-images.sh before flashing real
# hardware (pin ledger: docs/status.md).
OAUTH2_PROXY_IMAGE_TAG=v7.15.2
OAUTH2_PROXY_CLIENT_ID=REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com
OAUTH2_PROXY_CLIENT_SECRET=REPLACE_WITH_GOOGLE_OAUTH_CLIENT_SECRET
# 32-byte cookie encryption seed. Generate:
#   openssl rand -base64 32 | tr -- '+/' '-_'
OAUTH2_PROXY_COOKIE_SECRET=REPLACE_WITH_openssl_rand_base64_32
# Allow-list of Google accounts permitted through (Q10.5: explicit list to start;
# a remote-settable console is a deferred FUTURE knob, not built). Comma- or
# space-separated. The first-boot flow writes each entry, one per line, into
# oauth2-proxy/authenticated-emails.txt (gitignored) which the container reads.
OAUTH2_PROXY_ALLOWED_EMAILS=you@gmail.com,other-allowed@gmail.com

# ── Technitium DNS ─────────────────────────────────────────────────────────
# PINNED (Q10.9 B+): concrete version baked into the ISO payload and docker-loaded
# at first boot. This is the exact image the AWOW-sim validated (V1: latest ==
# 15.2.0, amd64 manifest verified byte-identical). Bump deliberately + re-export.
TECHNITIUM_IMAGE_TAG=15.2.0
# Initial admin password (set on first boot; provision script is idempotent).
TECHNITIUM_ADMIN_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD
# API token NAME the provisioning script creates/reuses for headless health/config.
# The token VALUE is generated by Technitium and written to provision/.token
# (gitignored) for later curl-based health checks.
TECHNITIUM_API_TOKEN_NAME=automation
# Upstream forwarders for recursion fallback / DoH. Quad9 DoH by default;
# space-separated. Empty = pure recursion.
TECHNITIUM_FORWARDERS=https://dns.quad9.net/dns-query
# Blocklist URLs (space-separated). Same public lists Pi-hole/AdGuard consume.
TECHNITIUM_BLOCKLISTS=https://raw.githubusercontent.com/StevenBlack/hosts/master/hosts

# ── tracker service (NagLight web container) ───────────────────────────────
# The image is built LOCALLY from a sibling NagLight checkout (Q10.2, no registry
# yet):  docker build -t naglight:local ../NagLight
# Git remote of the DATA repo (your private definitions+logs repo).
# The tracker container clones this into its /data volume on first boot and
# `git pull --rebase` on later boots. Leave blank to manage /data manually.
# NOTE: in multi-user mode (TRACKER_MULTI_USER=true) leave this BLANK and keep
# TRACKER_COMMIT=false — hosted users get per-user data dirs, git stays off (D3).
TRACKER_DATA_REMOTE=
# Identity the tracker uses for its check-off / nightly-materialize commits.
TRACKER_GIT_NAME=naglight bot
TRACKER_GIT_EMAIL=tracker@example.tld
# When true, `tracker serve --commit` — the nightly materialize + check-offs
# commit (and, if the remote is set, push) to the data repo. Single-user only.
TRACKER_COMMIT=true
# Trusted-header multi-user mode (D3, NagLight WI-10.5). true = identity comes
# ONLY from oauth2-proxy's X-Forwarded-Email header; per-user data dir by Google
# `sub`. Keep TRACKER_COMMIT=false and TRACKER_DATA_REMOTE blank when true.
TRACKER_MULTI_USER=false

# ── Auxiliary LAN-only observability (WI-10.11) ────────────────────────────
# Each UI is published bound to LAN_IP only (reachable on the LAN, never proxied
# to the public internet). Change the host ports if they collide with something.
# Uptime-Kuma (generic up-checks; can POST to NagLight /api/feed).
# PINNED (Q10.9 B+): concrete tag baked into the payload (was the floating `1`).
UPTIMEKUMA_IMAGE_TAG=1.23.17
UPTIMEKUMA_PORT=3001
# Dozzle (live container log viewer; reads the docker socket read-only).
# PINNED (Q10.9 B+): concrete tag baked into the payload (was the floating `v8`).
DOZZLE_IMAGE_TAG=v8.14.12
DOZZLE_PORT=8081
# ntfy (OPTIONAL self-hosted push; opt-in via `docker compose --profile ntfy up`).
# PINNED (Q10.9 B+): concrete tag baked into the payload (was floating `latest`).
NTFY_IMAGE_TAG=v2.25.0
NTFY_PORT=8090

# ── Dynamic DNS (Cloudflare) — AWOW owns DDNS per WI-9 Q4 ──────────────────
# Keeps the apex + wildcard (*.DOMAIN) A records pointed at the home
# connection, checked every DDNS_PERIOD. Replaces the legacy
# DDNS-Cloudflare-PowerShell scripts that ran on Mini-serv.
# Create a NEW scoped API token (permissions: Zone -> DNS -> Edit, only for
# this zone) at dash.cloudflare.com -> My Profile -> API Tokens.
# Do NOT reuse the old token from \\Mini-serv\setup — it sat in PLAINTEXT on
# the share and is flagged for rotation (WI-9.1 secrets finding).
# PINNED (Q10.9 B+): concrete release baked into the payload (was floating `latest`).
DDNS_IMAGE_TAG=v2.10.0
# Check/update cadence ("a few minutes").
DDNS_PERIOD=5m
CLOUDFLARE_ZONE_ID=REPLACE_WITH_CLOUDFLARE_ZONE_ID
CLOUDFLARE_API_TOKEN=REPLACE_WITH_NEW_SCOPED_DNS_EDIT_TOKEN

# ── Image tags (PINNED for reproducibility — Q10.9 B+ ALL-IMAGES) ───────────
# Every tag here is a CONCRETE version that is docker-saved into the ISO deploy
# payload and docker-loaded at first boot (vmtest/export-images.sh + firstboot.sh),
# so what boots == what the AWOW-sim validated. Floating tags (`latest`, `2-alpine`,
# `v8`) are now WRONG here: they let first boot drift from the validated set. Bump
# a pin ONLY deliberately, then re-run export-images.sh and rebuild the payload.
# The full pin set + registry digests are recorded in docs/status.md.
CADDY_IMAGE_TAG=2.11.4-alpine
# Local NagLight image tag (built with `docker build -t naglight:local ../NagLight`).
# Stays `local`: no registry home (Q10.2) — this is THE image the AWOW can never
# pull, so export-images.sh fails loudly if it isn't built before baking the payload.
TRACKER_IMAGE_TAG=local
ACTUAL_IMAGE_TAG=26.7.0

# ── Host / timezone (used by autoinstall) ──────────────────────────────────
TIMEZONE=Etc/UTC

# ═════════════════════════════════════════════════════════════════════════════
# TIER-2 OPT-IN CATALOG (SR-012) — everything below configures services that are
# OFF by default (compose profiles; see the docker-compose.yml tier-2 banner and
# stack/README §9). Filling these in changes NOTHING until a profile is enabled.
# ═════════════════════════════════════════════════════════════════════════════

# Which opt-in profiles start (comma-separated). This is THE enable switch:
# compose reads it from .env, so firstboot's plain `docker compose up -d` brings
# these up too — set it BEFORE building the USB and the box boots with them.
# Empty = core stack only. Photo stacks: run at most ONE of immich/photoprism;
# immich-ml is separate and heavy (leave off on the J4125).
#   e.g. COMPOSE_PROFILES=navidrome,audiobookshelf,vaultwarden,diun,ntfy
COMPOSE_PROFILES=

# HOST directory media libraries live under (bind-mounted into the media
# services; subdirs: music/ podcasts/ audiobooks/ photos/ immich/). Docker
# creates missing dirs, but the POINT is to aim this at real storage — NOT the
# WI-10.10 backup drives (serving media would defeat their spin-down policy).
MEDIA_ROOT=/srv/media

# Extra split-horizon subdomains (space/comma-separated bare labels), each gets
# an A record → LAN_IP at provisioning. Add a label when you uncomment its
# Caddyfile site, e.g.:  EXTRA_SUBDOMAINS=vault photos music audio
EXTRA_SUBDOMAINS=

# ── tier-2 image pins ────────────────────────────────────────────────────────
# Best-effort pins as of 2026-07 authoring — NOT sim-validated (unlike the core
# pins above) and NOT baked into the ISO payload unless you export with their
# profile (vmtest/export-images.sh EXTRA_PROFILES). VERIFY the current release
# at enable time; the diun profile watches them for updates afterwards.

# Photos option A: Immich (server + ML share one version; DB image tag comes
# from Immich's release notes — bump BOTH deliberately, they move together).
IMMICH_IMAGE_TAG=v3.0.2
IMMICH_DB_IMAGE_TAG=14-vectorchord0.4.3-pgvectors0.2.0
IMMICH_REDIS_IMAGE_TAG=9
IMMICH_PORT=2283
IMMICH_DB_USERNAME=immich
IMMICH_DB_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD
IMMICH_DB_DATABASE=immich
# true ONLY when the immich-ml profile is also enabled (semantic search + faces).
IMMICH_ML_ENABLED=false

# Photos option B: PhotoPrism (upstream publishes `latest` as THE stable tag —
# the exception to concrete pins here; diun flags when it moves).
PHOTOPRISM_IMAGE_TAG=latest
PHOTOPRISM_DB_IMAGE_TAG=11
PHOTOPRISM_PORT=2342
PHOTOPRISM_ADMIN_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD
PHOTOPRISM_DB_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD

# Video: Jellyfin (QSV transcode needs /dev/dri — see the compose devices note).
JELLYFIN_IMAGE_TAG=10.10.7
JELLYFIN_PORT=8096

# Music: Navidrome (Subsonic API).
NAVIDROME_IMAGE_TAG=0.53.3
NAVIDROME_PORT=4533

# Podcasts + audiobooks: Audiobookshelf.
AUDIOBOOKSHELF_IMAGE_TAG=2.17.5
AUDIOBOOKSHELF_PORT=13378

# Passwords: Vaultwarden — HTTPS-only via the Caddyfile vault.* site (no LAN
# port on purpose). Flip signups on for first-account creation, then back off.
VAULTWARDEN_IMAGE_TAG=1.33.2
VAULTWARDEN_SIGNUPS_ALLOWED=false

# Home automation: Home Assistant (monthly YYYY.M releases) + Mosquitto (MQTT).
HOMEASSISTANT_IMAGE_TAG=2026.7
MOSQUITTO_IMAGE_TAG=2.0
MOSQUITTO_PORT=1883

# Files: Syncthing (set a GUI password on first visit to the web UI).
SYNCTHING_IMAGE_TAG=1.29.2
SYNCTHING_GUI_PORT=8384

# Quality-of-life: RSS, recipes, LAN dashboard.
FRESHRSS_IMAGE_TAG=1.25.0
FRESHRSS_PORT=8082
MEALIE_IMAGE_TAG=v2.4.2
MEALIE_PORT=9925
HOMEPAGE_IMAGE_TAG=v0.10.9
HOMEPAGE_PORT=3002

# Ops: diun — update NOTIFIER for the pinned images (never auto-updates).
# Endpoint targets the ntfy container over the bridge — enable the ntfy profile
# alongside, or point this at any external ntfy server.
DIUN_IMAGE_TAG=4.29.0
DIUN_NTFY_ENDPOINT=http://ntfy:80
DIUN_NTFY_TOPIC=awow-updates
