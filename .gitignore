# Local environment + tool caches (Python reference stack — extend for yours)
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
.ruff_cache/

# Generated traceability views — regenerated by scripts/trace.py on every run
# (CI uploads them as artifacts; committing them just churns diffs). The report
# and the HTML map are composite renderings of the registries; review the CSVs,
# not these (process.md §3 "Reviewability").
docs/test/report.md
docs/test/report.html

# Performance comparator artifacts (process.md §9). perf-report.md is a
# regenerated composite; perf-metrics.json is the product-emitted raw
# measurement. Both are gitignored — the tracked source of truth is
# performance-budgets.csv, and the committed golden is perf-baseline.json
# (which is NOT ignored: a regression is accepted by committing its diff).
docs/test/perf-report.md
docs/test/perf-metrics.json

# No-stub / substance detector report (process.md §4 G3) — a regenerated
# composite from scripts/check_stubs.py; review the code, not this list.
docs/test/stub-report.md

# ── Deploy stack secrets & runtime state (WI-10.1) — NEVER commit these ──────
# Filled-in env, the Technitium API token, and the first-boot marker. Only the
# *.example templates are tracked.
stack/.env
stack/provision/.token
stack/.provisioned
# oauth2-proxy allow-list holds real Google accounts — only the .example tracked.
stack/oauth2-proxy/authenticated-emails.txt
# A filled-in autoinstall user-data carries the real SSH key / password hash.
stack/autoinstall/user-data.filled
# Local compose overrides / bind-mounted runtime volumes.
stack/docker-compose.override.yml
stack/caddy_data/
stack/caddy_config/

# ── V3 gate: local Hyper-V VM smoke-test harness (WI-10.18) ──────────────────
# Everything build-seed.sh / build-repacked-iso.sh / export-images.sh produce:
# the rendered SIM user-data/meta-data/.env, the deploy-payload repo copy, the
# Q10.9 B+ docker-save image tars (vmtest/.out/images/*.tar) + their manifest,
# the ephemeral SSH keypair, the SIM console/Technitium/oauth2-proxy secrets, the
# seed ISO, and (if downloaded/repacked for a smoke test) the multi-GB Ubuntu
# ISOs. NONE of this is ever committed — regenerate with the vmtest/ scripts.
vmtest/.out/
vmtest/*.iso

