# Caddyfile for the AWOW always-on core.
#
# Split-horizon: the SAME hostnames resolve to this box's LAN IP at home
# (Technitium) and to the public IP away (public DNS + router forward). Because
# the hostname never changes, the public cert Caddy obtains via ACME validates on
# the LAN too — no cert warnings, no internal hostname.
#
# AUTH MODEL (WI-10.2, decisions D1/D2):
#   - tracker.<domain>  -> oauth2-proxy (Google sign-in). NO basic_auth on this
#     host; oauth2-proxy is the gate and forwards verified identity headers
#     (X-Forwarded-Email / X-Forwarded-User) to the tracker container.
#   - actual.<domain>, dns.<domain>, map.<domain> -> KEEP basic_auth (Peter's
#     single-user services; oauth2-proxy is only for the multi-user tracker).
#
# Env vars (set in docker-compose.yml from .env):
#   {$DOMAIN} {$LAN_IP} {$TRACKER_HOST} {$ACTUAL_HOST} {$ACME_EMAIL} {$MAIN_BOX_IP}
#   {$ACTUAL_BASICAUTH_USER} {$ACTUAL_BASICAUTH_HASH}
#   {$DNS_BASICAUTH_USER} {$DNS_BASICAUTH_HASH}

{
    # ACME account email for public certs (Let's Encrypt / ZeroSSL).
    email {$ACME_EMAIL}
}

# ── shared snippets: one basic_auth guard per single-user service ─────────────
# Caddy resolves {$VAR} at config-load, so a single (protect) snippet can't carry
# two different credential pairs; give each guarded host its own snippet.
(protect_actual) {
    basic_auth {
        {$ACTUAL_BASICAUTH_USER} {$ACTUAL_BASICAUTH_HASH}
    }
}
(protect_dns) {
    basic_auth {
        {$DNS_BASICAUTH_USER} {$DNS_BASICAUTH_HASH}
    }
}

# ── tracker.<domain> — the NagLight tracker (multi-user via oauth2-proxy) ──────
# D2: NO basic_auth here. Caddy hands the whole host to oauth2-proxy, which runs
# the Google OAuth flow and reverse-proxies to the tracker container on success,
# injecting the identity headers the tracker's trusted-header mode reads (D3).
# The /oauth2/* callback + sign-in routes live inside oauth2-proxy too.
{$TRACKER_HOST} {
    encode zstd gzip
    reverse_proxy oauth2-proxy:4180 {
        # oauth2-proxy needs the original host/scheme to build its redirect URL.
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
    }
}

# ── actual.<domain> — Actual Budget (single-user; KEEP basic_auth) ─────────────
{$ACTUAL_HOST} {
    import protect_actual
    encode zstd gzip
    reverse_proxy actual:5006
}

# ── dns.<domain> — Technitium web console (single-admin; KEEP basic_auth) ──────
# Technitium binds :5380 on the host (host-network); proxy to the host gateway.
dns.{$DOMAIN} {
    import protect_dns
    encode zstd gzip
    # host.docker.internal → the host where Technitium's :5380 lives.
    reverse_proxy host.docker.internal:5380
}

# ── main-box services (BlueMap / Minecraft map etc.) — COMMENTED, opt-in ───────
# A flaky MAIN box may host the heavy services. Uncomment + set MAIN_BOX_IP in
# .env to have Caddy on THIS box reverse-proxy across the LAN to them. The
# provisioning script already creates a `map.<domain>` split-horizon record when
# MAIN_BOX_IP is set, so this just wires the proxy. KEEP basic_auth on these.
#
# map.{$DOMAIN} {
#     import protect_dns
#     encode zstd gzip
#     reverse_proxy {$MAIN_BOX_IP}:8100   # BlueMap default web port
# }

# ── tier-2 opt-in public sites (SR-012) — COMMENTED, uncomment per service ─────
# Publishing a tier-2 service is a deliberate THREE-step opt-in:
#   1. enable its compose profile (COMPOSE_PROFILES in .env),
#   2. uncomment its block here,
#   3. add its label to EXTRA_SUBDOMAINS in .env (split-horizon record).
# Every service below carries its OWN login — do NOT wrap them in basic_auth;
# their mobile/desktop clients authenticate against the app's API directly and
# a second auth layer breaks them. Most are also LAN-reachable on their LAN_IP
# port bind (exception: Vaultwarden, which is HTTPS-only by design — this site
# IS its ingress).
#
# vault.{$DOMAIN} {          # Vaultwarden — the Bitwarden clients point here
#     encode zstd gzip
#     reverse_proxy vaultwarden:80
# }
# photos.{$DOMAIN} {         # Immich — the mobile app needs this for away-from-home auto-backup
#     encode zstd gzip
#     reverse_proxy immich-server:2283
# }
# prism.{$DOMAIN} {          # PhotoPrism
#     encode zstd gzip
#     reverse_proxy photoprism:2342
# }
# jellyfin.{$DOMAIN} {       # Jellyfin
#     encode zstd gzip
#     reverse_proxy jellyfin:8096
# }
# music.{$DOMAIN} {          # Navidrome — Subsonic clients point here
#     encode zstd gzip
#     reverse_proxy navidrome:4533
# }
# audio.{$DOMAIN} {          # Audiobookshelf — its apps point here
#     encode zstd gzip
#     reverse_proxy audiobookshelf:80
# }
# home.{$DOMAIN} {           # Home Assistant — host-network, so proxy to the host.
#     encode zstd gzip       # HA rejects proxied requests until Caddy is listed in
#     reverse_proxy host.docker.internal:8123    # trusted_proxies in its config.
# }

# ── apex — bare domain answers on-LAN too ──────────────────────────────────────
{$DOMAIN} {
    respond "AWOW always-on core. Try https://{$TRACKER_HOST}" 200
}
